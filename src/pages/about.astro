    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <Header />
	<a href={wikiUrl} target="_blank" rel="noopener noreferrer">
      <h1>{pageTitle}</h1>
    </a>
	You've reached the digital attic where I <a href={linkedInUrl}>(linkedin.com/in/colum-crowe)</a> dump stuff onto the web.<br>
    Here's where I overthink all the <em>little things</em> I enjoy.<br>
    <h1>Under construction</h1>
    <h2>Work in progress...</h2>
    <img src="https://raw.githubusercontent.com/columcrowe/columcrowe.github.io/refs/heads/main/src/assets/WIP.gif" alt="wip" width="300" height="200" />
    <Footer />
    <script>
      import "../scripts/menu.js";
    </script>
  </body>
</html>



